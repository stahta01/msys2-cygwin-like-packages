_realname=binutils
_mingw_cygwin_suff=mingw-w64-cygwin-like-cross
_mingw_suff=mingw-w64-cross
pkgname=("${_mingw_cygwin_suff}-${_realname}")
pkgver=2.40
pkgrel=1
pkgdesc="A set of programs to assemble and manipulate binary and object files"
arch=('i686' 'x86_64')
url="https://www.gnu.org/software/binutils/"
license=('GPL')
groups=("${_mingw_cygwin_suff}-toolchain" "${_mingw_cygwin_suff}")
depends=("libiconv" "zlib")
checkdepends=('dejagnu' 'bc')
makedepends=("libiconv" "zlib" 'autotools' 'gcc')
options=('staticlibs' '!distcc' '!ccache' '!buildflags')
source=(https://ftp.gnu.org/gnu/binutils/binutils-${pkgver}.tar.xz{,.sig}
        001-enable-gold-on.mingw32.patch
        002-check-for-unusual-file-harder.patch
        010-bfd-Increase-_bfd_coff_max_nscns-to-65279.patch
        020-binutils_2.31_mkdtemp_impl.patch
        100-binutils-2.37-msys2.patch
        110-binutils-2.40-mingw-gnu-print.patch
        120-windres-handle-spaces.patch)
sha256sums=('0f8a4c272d7f17f369ded10a4aca28b8e304828e95526da482b0ccc4dfc9d8e1'
            'SKIP'
            '93296b909e1a4f9d8a4bbe2437aafa17ca565ef6642a9812b0360c05be228c9d'
